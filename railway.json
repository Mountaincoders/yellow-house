{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "context": "."
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "pnpm -F backend start",
    "healthchecks": {
      "readiness": {
        "path": "/health",
        "initialDelaySeconds": 10
      }
    }
  }
}
